              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/demo-requests/1/activity",
              "host": ["{{base_url}}"],
