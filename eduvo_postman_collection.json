              "raw": "{\n  \"datetime\": \"2026-10-12T10:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/demo-requests/1/schedule",
              "host": ["{{base_url}}"],
              "path": ["demo-requests", "1", "schedule"]
            }
          }
        },
        {
          "name": "Conflict Schedule Test",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"datetime\": \"2026-10-10T10:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/demo-requests/2/schedule",
              "host": ["{{base_url}}"],
              "path": ["demo-requests", "2", "schedule"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Status Management",
      "item": [
        {
          "name": "Update Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/demo-requests/1/status",
              "host": ["{{base_url}}"],
              "path": ["demo-requests", "1", "status"]
            }
          }
        },
        {
          "name": "Invalid Status Transition Test",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
